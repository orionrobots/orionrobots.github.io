# Orionrobots local environment configuration
# Copy this to .env and fill in values as needed.
# .env is gitignored — never commit credentials.

# ── Performance testing ────────────────────────────────────────────────────────

# Base URL for performance measurements.
# Default (production):
#   BASE_URL=https://orionrobots.co.uk
# Local Docker server (start first with: docker compose up serve):
#   BASE_URL=http://serve:8081
BASE_URL=https://orionrobots.co.uk

# Google Cloud API key for PageSpeed Insights data.
# Only used when BASE_URL is the production site.
# Create a key at https://console.cloud.google.com/apis/credentials
# and enable the "PageSpeed Insights API".
PAGESPEED_API_KEY=

# Number of Playwright measurement runs per page (median is reported).
# More runs = more stable numbers, but slower overall execution.
PERF_RUNS=3

# Optional: path to write a JSON report file (e.g. perf-report.json).
# Leave blank to skip file output.
OUTPUT_JSON=
